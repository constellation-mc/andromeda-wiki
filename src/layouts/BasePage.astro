---
import BaseHead from "../components/BaseHead.astro";
import { normalizeLangTag } from "../lib/i18n";

import "./base.css";

type Props = {
  title: string;
  locale: string;
  tags?: string[];
  description?: string;
};

const { title, locale, tags, description } = Astro.props;
const lang = normalizeLangTag(locale);
---

<html {lang}>
  <BaseHead {title} {description} {tags} />
  <body> <slot /> </body><script is:inline>
    document.querySelectorAll(".lazy-video").forEach((video) => {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const source = video.querySelector("source");
              if (source?.dataset.src) {
                source.src = source.dataset.src;
                video.load();
                video.play();
              }
              obs.unobserve(video);
            }
          });
        },
        { rootMargin: "50px" },
      );

      observer.observe(video);
    });
  </script>
</html>

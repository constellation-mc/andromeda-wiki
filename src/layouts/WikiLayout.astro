---
import BasePage from "./BasePage.astro";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";
import TablerIcon from "../components/TablerIcon.astro";
import TableOfContents from "../components/TableOfContents.astro";
import "./layout.css";

import { type MarkdownHeading } from "astro";
import { type Version, DEFAULT_VERSION, SEMVERS } from "../lib/versions";
import { DEFAULT_LOCALE, t } from "../lib/i18n";

type Props = {
  title: string;
  locale: string;
  version: Version;
  translations: Map<string, string>;
  headings: MarkdownHeading[];
  page: string;
  fallback?: boolean;
  description?: string;
};

const {
  title,
  locale,
  version: currentVersion,
  description,
  translations,
  headings,
  page,
  fallback = false,
} = Astro.props;
const version = currentVersion ?? DEFAULT_VERSION;
const legacy =
  SEMVERS.indexOf(version.semver) > SEMVERS.indexOf(DEFAULT_VERSION.semver);

const cleanPath = page.replace(/^\/+|\/+$/g, "").replace(/\/?index\/?$/, "");
const canonical = cleanPath
  ? `${Astro.url.origin}/${cleanPath}/`
  : `${Astro.url.origin}/`;

const content = headings.filter((h) => h.depth == 2);
const tags = ["minecraft", "andromeda", "mod"];
---

<BasePage
  title={`${title} | ${t(locale, "base.title")} (${version.semver})`}
  locale={fallback ? DEFAULT_LOCALE : locale}
  {description}
>
  <Fragment slot="head">
    {tags.map((t) => <meta property="article:tag" content={t} />)}
    <link rel="canonical" href={canonical} />
  </Fragment>

  <div class="wrapper">
    <Sidebar {locale} {version} {translations} />
    <a class="sidebar-close" href="#"></a>

    <main>
      <Header {locale} {version} />

      <div class="nav-wrapper">
        <a class="sidebar-button" href="#sidebar">
          <TablerIcon icon="list-details">
            <span>{t(locale, "sidebar.button")}</span>
          </TablerIcon></a
        >

        {
          content.length == 0 && (
            <a class="article-top" href="#">
              <TablerIcon icon="arrow-back-up">
                <span>{t(locale, "content.top")}</span>
              </TablerIcon>
            </a>
          )
        }

        {
          content.length > 0 && (
            <details class="static">
              <summary>
                <span>{t(locale, "content.title")}</span>
              </summary>

              {content.length > 0 && <TableOfContents {locale} {content} />}
            </details>
          )
        }
      </div>

      <div class="article-wrapper">
        {
          fallback && (
            <div class="remark-container warning translation">
              <p>{t(locale, "content.lang.missing")}</p>
              <a
                target="_blank"
                href={`https://github.com/constellation-mc/andromeda-wiki/`}
              >
                <TablerIcon icon="edit">
                  <span>{t(locale, "content.lang.translate")}</span>
                </TablerIcon>
              </a>
            </div>
          )
        }

        <article>
          <h1>{title}</h1>
          {description && <p>{description}</p>}
          <slot />
        </article>

        <div class="article-bottom">
          <a
            target="_blank"
            href={`https://github.com/constellation-mc/andromeda-wiki/edit/main/src/content/docs/${page}.md`}
          >
            <TablerIcon icon="edit">
              <span>{t(locale, "content.edit")}</span>
            </TablerIcon>
          </a>
        </div>

        <hr />
      </div>

      <aside>
        <h3>{t(locale, "content.title")}</h3>
        <TableOfContents {locale} {content} />
      </aside>
    </main>
  </div>
</BasePage>
